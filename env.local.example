# =============================================================================
# Auth0 Configuration
# =============================================================================
# Copy this file to .env.local and fill in your Auth0 values.
#
# 1. Create an Auth0 tenant at https://auth0.com
# 2. Create a "Regular Web Application" in Auth0 Dashboard
# 3. Set Allowed Callback URLs:    http://localhost:3000/auth/callback
# 4. Set Allowed Logout URLs:      http://localhost:3000
# 5. Set Allowed Web Origins:      http://localhost:3000
# =============================================================================

# Auth0 domain (e.g. your-tenant.us.auth0.com)
AUTH0_DOMAIN=<your-auth0-domain>

# Auth0 application Client ID
AUTH0_CLIENT_ID=<your-client-id>

# Auth0 application Client Secret
AUTH0_CLIENT_SECRET=<your-client-secret>

# A long secret value used to encrypt the session cookie (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH0_SECRET=<your-random-secret>

# Your application base URL
APP_BASE_URL=http://localhost:3000

# =============================================================================
# Auth0 API / RBAC (Optional — required for roles & permissions in tokens)
# =============================================================================
# Create an API in Auth0 Dashboard > Applications > APIs
# Set the identifier (audience) below
AUTH0_AUDIENCE=<your-api-audience>

# =============================================================================
# Auth0 Dashboard Setup for Full Feature Support
# =============================================================================
#
# --- Social Connections (Google & Apple) ---
# 1. Go to Authentication > Social
# 2. Enable "Google" — provide your Google OAuth Client ID & Secret
# 3. Enable "Apple" — provide your Apple Services ID, Team ID, Key ID, and Private Key
#
# --- Multi-Factor Authentication (2FA) ---
# 1. Go to Security > Multi-factor Auth
# 2. Enable at least one factor (e.g. One-time Password, SMS, Push via Guardian)
# 3. Set the policy to "Always" or "Adaptive" depending on your needs
#
# --- Role-Based Access Control (RBAC) ---
# 1. Go to Applications > APIs > your API > Settings
# 2. Enable "Enable RBAC" and "Add Permissions in the Access Token"
# 3. Define permissions under the API's "Permissions" tab:
#    - read:appointments, write:appointments
#    - read:patients, write:patients
#    - read:billing, write:billing
#    - manage:clinic, manage:users
# 4. Go to User Management > Roles and create roles:
#    - admin, clinic_owner, practitioner, receptionist, patient
# 5. Assign permissions to each role
# 6. Assign roles to users
#
# --- Custom Claims (Roles/Permissions in ID Token) ---
# Create a Login / Post Login Action in Auth0 Dashboard > Actions > Flows > Login:
#
#   exports.onExecutePostLogin = async (event, api) => {
#     const namespace = 'https://nextjs-auth0-sample.com';
#     const roles = event.authorization?.roles || [];
#     const permissions = event.authorization?.permissions || [];
#     api.idToken.setCustomClaim(`${namespace}/roles`, roles);
#     api.idToken.setCustomClaim(`${namespace}/permissions`, permissions);
#     api.accessToken.setCustomClaim(`${namespace}/roles`, roles);
#     api.accessToken.setCustomClaim(`${namespace}/permissions`, permissions);
#   };
